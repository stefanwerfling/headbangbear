{
    "name": "@headbangbear/backend",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "description": "Headbangbear backend - figtree-based music analysis API",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc -p .",
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js",
        "typecheck": "tsc --noEmit -p tsconfig.test.json",
        "test": "vitest run",
        "test:watch": "vitest",
        "analyze": "tsx src/Cli/Analyze.ts",
        "compatible": "tsx src/Cli/Compatible.ts",
        "mix-plan": "tsx src/Cli/MixPlan.ts",
        "dj-set": "tsx src/Cli/DjSet.ts",
        "key-eval": "tsx src/Cli/KeyEval.ts"
    },
    "dependencies": {
        "@headbangbear/schemas": "*",
        "essentia.js": "^0.1.3",
        "figtree": "git+https://github.com/stefanwerfling/figtree.git#claude",
        "figtree-schemas": "github:stefanwerfling/figtree-schemas",
        "music-metadata": "^10.5.0",
        "vts": "github:OpenSourcePKG/vts"
    },
    "devDependencies": {
        "@types/express": "^5.0.6",
        "@types/node": "^22.9.0",
        "tsx": "^4.19.2",
        "vitest": "^2.1.9"
    }
}
